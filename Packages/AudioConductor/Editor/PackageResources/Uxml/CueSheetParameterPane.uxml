<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement>
        <ui:VisualElement name="Rox" style="flex-direction: row;">
            <ui:TextField picking-mode="Ignore" label="CueSheet Name" value="filler text" name="Name" is-delayed="true" style="flex-basis: 33.333%;" />
        </ui:VisualElement>
        <ui:VisualElement name="Row" style="flex-direction: row;">
            <AudioConductor.Editor.Core.Tools.Shared.ThrottleTypeField style="flex-basis: 33.333%;" />
        </ui:VisualElement>
        <ui:VisualElement name="Row" style="flex-direction: row;">
            <uie:IntegerField label="Throttle Limit" name="ThrottleLimit" is-delayed="true" style="flex-basis: 33.333%;" />
        </ui:VisualElement>
        <ui:VisualElement name="Row" style="flex-direction: row;">
            <AudioConductor.Editor.Core.Tools.Shared.SliderAndFloatField name="Volume" label="Volume" value="1" high-value="1" is-delayed="true" style="flex-basis: 33.333%;" />
        </ui:VisualElement>
        <ui:VisualElement name="Row" style="flex-direction: row;">
            <AudioConductor.Editor.Core.Tools.Shared.SliderAndFloatField name="Pitch" label="Pitch" value="1" high-value="3" is-delayed="true" style="flex-basis: 33.333%;" />
        </ui:VisualElement>
        <ui:VisualElement name="Row" style="flex-direction: row;">
            <ui:Toggle label="Pitch Invert" name="PitchInvert" style="flex-basis: 33.333%; padding-top: 2px;" />
        </ui:VisualElement>
        <ui:VisualElement name="Row" style="flex-direction: row; margin-top: 8px;">
            <ui:Toggle label="Code Gen Enabled" name="CodeGenEnabled" style="flex-basis: 33.333%; padding-top: 2px;" />
        </ui:VisualElement>
        <ui:VisualElement name="CodeGenSettings">
            <ui:VisualElement name="Row" style="flex-direction: row;">
                <ui:TextField picking-mode="Ignore" label="Output Path" value="" name="CodeGenOutputPath" is-delayed="true" tooltip="Directory for the generated enum file. Default: Assets/Scripts/Generated/" style="flex-basis: 33.333%;" />
            </ui:VisualElement>
            <ui:VisualElement name="Row" style="flex-direction: row;">
                <ui:TextField picking-mode="Ignore" label="Namespace" value="" name="CodeGenNamespace" is-delayed="true" tooltip="Namespace for the generated enum. Empty means no namespace." style="flex-basis: 33.333%;" />
            </ui:VisualElement>
            <ui:VisualElement name="Row" style="flex-direction: row;">
                <ui:TextField picking-mode="Ignore" label="Class Suffix" value="" name="CodeGenClassSuffix" is-delayed="true" tooltip="Suffix appended to the CueSheet name to form the enum type name. e.g. BGM + Cues = BGMCues. Empty means CueSheet name only." style="flex-basis: 33.333%;" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
