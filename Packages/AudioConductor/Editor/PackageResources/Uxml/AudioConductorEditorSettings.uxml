    <ui:ListView focusable="true" reorderable="true" reorder-mode="Animated" show-border="true" show-add-remove-footer="true" show-foldout-header="true" header-title="Color Define" show-alternating-row-backgrounds="All" fixed-item-height="20" style="margin-left: 3px; margin-right: 3px; margin-top: 3px; margin-bottom: 1px;" />
</ui:UXML>
