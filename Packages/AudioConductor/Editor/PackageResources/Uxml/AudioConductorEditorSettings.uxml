    <uie:EnumField name="Language" label="Language" style="margin-left: 3px; margin-right: 3px; margin-top: 3px; margin-bottom: 3px;" />
    <ui:TextField name="DefaultCodeGenOutputPath" label="CodeGen Output Path" is-delayed="true" style="margin-left: 3px; margin-right: 3px; margin-top: 3px; margin-bottom: 3px;" />
